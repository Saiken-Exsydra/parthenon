  <script define:vars={{ services }}>
    // ── Intersection Observer: fade-in on scroll ──
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // ── Service modal ──
    const modal    = document.getElementById('service-modal');
    const modalIcon  = document.getElementById('modal-icon');
    const modalTitle = document.getElementById('modal-title');
    const modalPrices = document.getElementById('modal-prices');
    const closeBtn  = document.getElementById('modal-close');

    function openModal(index) {
      const svc = services[index];
      if (!svc || !modal) return;
      modalIcon.textContent  = svc.icon;
      modalTitle.textContent = svc.name;
      modalPrices.innerHTML  = svc.prices
        .map(p => `<li><span class="modal-price-name">${p.style}</span><span class="modal-price-value">${p.price}</span></li>`)
        .join('');
      modal.hidden = false;
      requestAnimationFrame(() => modal.classList.add('open'));
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('open');
      modal.addEventListener('transitionend', () => {
        modal.hidden = true;
        document.body.style.overflow = '';
      }, { once: true });
    }

    document.querySelectorAll('.service-card').forEach(card => {
      card.addEventListener('click', () => openModal(Number(card.dataset.service)));
    });

    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });
  </script>
