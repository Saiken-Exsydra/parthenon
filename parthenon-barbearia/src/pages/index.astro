---
// PARTHENON BARBEARIA — Single-page site
const WHATSAPP_URL  = 'https://wa.me/5534999992321';
const WHATSAPP_TEL  = '(34) 9 9999-2321';
const EMAIL         = 'parthenonbarbershop@hotmail.com';
const INSTAGRAM_URL = 'https://instagram.com/parthenonbarbearia';
const OWNER         = 'Marco Antônio';

const services = [
  {
    name: 'Cabelo',
    range: 'R$ 35–60',
    desc: 'Corte clássico ou moderno, sempre com precisão.',
    prices: [
      { style: 'Corte simples',  price: 'R$ 35' },
      { style: 'Corte degradê',  price: 'R$ 45' },
      { style: 'Navalhado',      price: 'R$ 55' },
      { style: 'Corte + barba',  price: 'R$ 60' },
    ],
  },
  {
    name: 'Barba',
    range: 'R$ 25–40',
    desc: 'Modelagem e acabamento com toalha quente.',
    prices: [
      { style: 'Apara simples',   price: 'R$ 25' },
      { style: 'Barba completa',  price: 'R$ 35' },
      { style: 'Barba navalhada', price: 'R$ 40' },
    ],
  },
  {
    name: 'Bigode',
    range: 'R$ 15–20',
    desc: 'Aparado e definido com navalha para acabamento limpo.',
    prices: [
      { style: 'Aparar e definir',     price: 'R$ 15' },
      { style: 'Modelagem completa',   price: 'R$ 20' },
    ],
  },
  {
    name: 'Sobrancelhas',
    range: 'R$ 15–25',
    desc: 'Design natural com acabamento preciso na navalha.',
    prices: [
      { style: 'Design com navalha', price: 'R$ 15' },
      { style: 'Design + henna',     price: 'R$ 25' },
    ],
  },
  {
    name: 'Química capilar',
    range: 'A consultar',
    desc: 'Progressiva, relaxamento e tratamentos sob avaliação.',
    prices: [
      { style: 'Progressiva',         price: 'A consultar' },
      { style: 'Relaxamento',         price: 'A consultar' },
      { style: 'Tratamento capilar',  price: 'A consultar' },
    ],
  },
];

const hours = [
  { day: 'Segunda', value: '10:00 – 19:00' },
  { day: 'Terça',   value: '10:00 – 18:00' },
  { day: 'Quarta',  value: '10:00 – 20:00' },
  { day: 'Quinta',  value: '10:00 – 20:00' },
  { day: 'Sexta',   value: '12:00 – 18:00' },
  { day: 'Sábado',  value: '10:00 – 15:30' },
  { day: 'Domingo', value: 'Fechado' },
];

const gallery = ['Cortes', 'Barba', 'Acabamento', 'Ambiente', 'Detalhes', 'Retratos'];
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="Parthenon Barbearia — Cabelo, barba, bigode, sobrancelhas e química capilar em Uberlândia, MG. Agende com Marco Antônio pelo WhatsApp." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Parthenon Barbearia — Uberlândia, MG</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Playfair+Display:wght@400;700;900&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #020202;
      --surface: #0a0f17;
      --surface-soft: rgba(8, 13, 22, 0.78);
      --ink: #ffffff;
      --muted: rgba(255, 255, 255, 0.62);
      --line: rgba(255, 255, 255, 0.11);
      --accent: #9a1f3d;
      --navy: #182866;
      --radius: 12px;
      --section-space: 4.5rem;
      --hero-pattern-size: 320px;
      --hero-overlay-start: 0.22;
      --hero-overlay-end: 0.68;
      --hero-card-shadow-alpha: 0.52;
      --font-display: "Playfair Display", Georgia, serif;
      --font-body: "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: #030303;
      color: var(--ink);
      font-family: var(--font-body);
      line-height: 1.65;
      min-width: 320px;
    }

    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; }

    .shell {
      background: #030303;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.8rem 1rem;
      background: rgba(0, 0, 0, 0.92);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 0;
    }

    .brand img {
      width: 52px;
      mix-blend-mode: screen;
    }

    .brand-copy {
      display: grid;
      gap: 0.1rem;
    }

    .brand-copy small {
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.56);
    }

    .brand-copy strong {
      font-family: var(--font-display);
      font-size: 1.15rem;
      letter-spacing: 0.06em;
      font-weight: 900;
    }

    .nav-link {
      padding: 0.8rem 1rem;
      border: 1px solid rgba(255, 255, 255, 0.34);
      border-radius: var(--radius);
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .hero {
      position: relative;
      min-height: 100svh;
      display: grid;
      place-items: center;
      padding: 5.5rem 1rem 2rem;
      background-color: #000;
      background-image: url("/BG1.png");
      background-repeat: repeat;
      background-size: var(--hero-pattern-size);
      overflow: clip;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 38%, rgba(0, 0, 0, var(--hero-overlay-start)), rgba(0, 0, 0, 0.8) 72%),
        linear-gradient(180deg, rgba(0, 0, 0, 0.26), rgba(0, 0, 0, var(--hero-overlay-end)));
    }

    .hero-card {
      position: relative;
      z-index: 1;
      width: min(100%, 33rem);
      text-align: center;
      padding: 2rem 1.25rem 2.2rem;
      background: rgba(0, 0, 0, 0.62);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      box-shadow: 0 0 90px 48px rgba(0, 0, 0, var(--hero-card-shadow-alpha));
    }

    .hero-logo {
      width: min(72vw, 220px);
      margin: 0 auto 1.75rem;
      mix-blend-mode: screen;
    }

    .hero-quote {
      margin: 0 0 0.85rem;
      font-family: var(--font-display);
      font-style: italic;
      font-size: clamp(1.7rem, 6vw, 2.5rem);
      line-height: 1.25;
    }

    .hero-byline {
      margin: 0 0 1.75rem;
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.5);
    }

    .hero-actions {
      display: grid;
      gap: 0.75rem;
    }

    .cta,
    .cta-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 0.95rem 1.2rem;
      border-radius: var(--radius);
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 500;
    }

    .cta {
      border: 1px solid rgba(255, 255, 255, 0.56);
      background: transparent;
      color: #fff;
    }

    .cta-secondary {
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.04);
      color: rgba(255, 255, 255, 0.82);
    }

    .scroll-note {
      position: absolute;
      bottom: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1;
      display: grid;
      justify-items: center;
      gap: 0.25rem;
      font-size: 0.64rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.34);
    }

    .container {
      width: min(100% - 2rem, 68rem);
      margin: 0 auto;
    }

    section:not(.hero) {
      padding: var(--section-space) 0;
    }

    .section-light {
      background: #f4f7fa;
      color: #1a1a2e;
    }

    .section-white {
      background: #ffffff;
      color: #1a1a2e;
    }

    .section-head {
      margin-bottom: 2rem;
    }

    .section-head small {
      display: block;
      margin-bottom: 0.65rem;
      font-size: 0.72rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: #5a6a7a;
    }

    .section-head h2 {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(2rem, 7vw, 3rem);
      line-height: 1.12;
      color: #0d1b2a;
    }

    .rule {
      width: 48px;
      height: 1px;
      margin-top: 0.9rem;
      background: #d0dce8;
    }

    .services-grid {
      display: grid;
      gap: 1rem;
    }

    .service {
      border: 1px solid #d0dce8;
      border-radius: 10px;
      background: #fff;
      box-shadow: 0 2px 16px rgba(13, 27, 42, 0.08);
      overflow: clip;
    }

    .service-head {
      padding: 1.2rem 1rem;
      display: grid;
      gap: 0.5rem;
    }

    .service-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
    }

    .service-top h3 {
      margin: 0;
      font-size: 1.14rem;
      font-family: var(--font-display);
      color: #0d1b2a;
    }

    .price-range {
      font-size: 0.86rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #1a3a5c;
      white-space: nowrap;
    }

    .service p {
      margin: 0;
      color: #5a6a7a;
      font-size: 0.9rem;
    }

    .service-body {
      padding: 0 1rem 1rem;
    }

    .service-body ul {
      margin: 0;
      padding: 0;
      list-style: none;
      border-top: 1px solid #d0dce8;
    }

    .service-body li {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.8rem 0;
      border-bottom: 1px solid #d0dce8;
      font-size: 0.92rem;
    }

    .service-body li:last-child { border-bottom: 0; }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .gallery-cell {
      aspect-ratio: 1;
      border: 1px solid #d0dce8;
      border-radius: 10px;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(13, 27, 42, 0.04), rgba(13, 27, 42, 0.08)),
        url("/BG1.png");
      background-size: 230px;
      display: grid;
      place-items: end start;
      padding: 0.85rem;
    }

    .gallery-label {
      display: inline-flex;
      padding: 0.36rem 0.52rem;
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid rgba(13, 27, 42, 0.08);
      border-radius: 999px;
      color: #0d1b2a;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .hours-table {
      width: 100%;
      border-collapse: collapse;
    }

    .hours-table tr {
      border-bottom: 1px solid #d0dce8;
    }

    .hours-table td {
      padding: 0.85rem 0;
      font-size: 0.94rem;
    }

    .hours-table td:first-child {
      color: #5a6a7a;
    }

    .hours-table td:last-child {
      text-align: right;
      color: #1a1a2e;
      font-weight: 500;
    }

    .contact-grid {
      display: grid;
      gap: 1.5rem;
    }

    .contact-stack {
      display: grid;
      gap: 1rem;
    }

    .contact-item {
      display: grid;
      gap: 0.3rem;
    }

    .contact-item small {
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: #5a6a7a;
    }

    .contact-item strong,
    .contact-item a,
    .contact-item span {
      color: #1a1a2e;
      font-size: 0.98rem;
      font-weight: 400;
    }

    .contact-actions {
      display: grid;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }

    .contact-actions a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      border-radius: 10px;
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .whatsapp {
      background: #25d366;
      color: #fff;
    }

    .instagram {
      border: 1px solid #d0dce8;
      color: #1a1a2e;
    }

    .map {
      width: 100%;
      min-height: 320px;
      border: 1px solid #d0dce8;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 16px rgba(13, 27, 42, 0.08);
    }

    .map iframe {
      width: 100%;
      height: 100%;
      min-height: 320px;
      border: 0;
      display: block;
    }

    .footer {
      background: #f4f7fa;
      color: #1a1a2e;
      text-align: center;
      padding: 2.75rem 1rem 2rem;
      border-top: 1px solid #d0dce8;
    }

    .footer img {
      width: 84px;
      margin: 0 auto 1rem;
    }

    .footer strong {
      display: block;
      margin-bottom: 0.4rem;
      font-family: var(--font-display);
      font-size: 1.15rem;
      letter-spacing: 0.12em;
      color: #0d1b2a;
    }

    .footer p {
      margin: 0;
      color: #5a6a7a;
      font-size: 0.82rem;
    }

    @media (min-width: 700px) {
      .nav { padding-inline: 2rem; }
      .nav-link { padding-inline: 1.2rem; }
      .hero { background-size: auto; }
      .hero-card { padding: 2.5rem 2rem 2.7rem; }
      .services-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .gallery-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .contact-grid { grid-template-columns: 0.9fr 1.1fr; align-items: start; }
      .contact-actions { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (min-width: 980px) {
      .services-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
  </style>
</head>
<body>
  <div class="shell">
    <nav class="nav">
      <a class="brand" href="#inicio" aria-label="Parthenon Barbearia">
        <img src="/logo.png" alt="Parthenon Barbearia" />
        <span class="brand-copy">
          <small>Barbearia</small>
          <strong>Parthenon</strong>
        </span>
      </a>
      <a class="nav-link" href={WHATSAPP_URL} target="_blank" rel="noopener">Agendar</a>
    </nav>

    <section class="hero" id="inicio">
      <div class="hero-card">
        <img class="hero-logo" src="/logo.png" alt="Parthenon Barbearia" />
        <p class="hero-quote">“Cuidar da aparência não é vaidade — é o respeito silencioso que um homem tem por si mesmo.”</p>
        <p class="hero-byline">{OWNER} · Parthenon Barbearia</p>
        <div class="hero-actions">
          <a class="cta" href={WHATSAPP_URL} target="_blank" rel="noopener">Agendar pelo WhatsApp</a>
          <a class="cta-secondary" href="#servicos">Ver serviços</a>
        </div>
      </div>
      <div class="scroll-note" aria-hidden="true">
        <span>Rolar</span>
        <span>↓</span>
      </div>
    </section>

    <section class="section-light" id="servicos">
      <div class="container">
        <div class="section-head">
          <small>O que oferecemos</small>
          <h2>Nossos serviços, sem esconder preço.</h2>
          <div class="rule"></div>
        </div>
        <div class="services-grid">
          {services.map(s => (
            <article class="service">
              <div class="service-head">
                <div class="service-top">
                  <h3>{s.name}</h3>
                  <span class="price-range">{s.range}</span>
                </div>
                <p>{s.desc}</p>
              </div>
              <div class="service-body">
                <ul>
                  {s.prices.map(p => (
                    <li><span>{p.style}</span><strong>{p.price}</strong></li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-white" id="galeria">
      <div class="container">
        <div class="section-head">
          <small>Nosso trabalho</small>
          <h2>Galeria pronta para receber fotos reais.</h2>
          <div class="rule"></div>
        </div>
        <div class="gallery-grid">
          {gallery.map(label => (
            <div class="gallery-cell"><span class="gallery-label">{label}</span></div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-light" id="horarios">
      <div class="container">
        <div class="section-head">
          <small>Quando estamos abertos</small>
          <h2>Horários de funcionamento.</h2>
          <div class="rule"></div>
        </div>
        <table class="hours-table">
          <tbody>
            {hours.map(h => (
              <tr><td>{h.day}</td><td>{h.value}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="section-white" id="contato">
      <div class="container">
        <div class="section-head">
          <small>Fale conosco</small>
          <h2>Contato e localização</h2>
          <div class="rule"></div>
        </div>
        <div class="contact-grid">
          <div class="contact-stack">
            <div class="contact-item">
              <small>Barbeiro</small>
              <strong>{OWNER}</strong>
            </div>
            <div class="contact-item">
              <small>Endereço</small>
              <span>Rua da Fartura, 1767<br />Bairro Minas Gerais<br />Uberlândia – MG</span>
            </div>
            <div class="contact-item">
              <small>Telefone / WhatsApp</small>
              <a href={`tel:${WHATSAPP_URL.replace('https://wa.me/','')}`}>{WHATSAPP_TEL}</a>
            </div>
            <div class="contact-item">
              <small>E-mail</small>
              <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
            </div>
            <div class="contact-actions">
              <a class="whatsapp" href={WHATSAPP_URL} target="_blank" rel="noopener">Chamar no WhatsApp</a>
              <a class="instagram" href={INSTAGRAM_URL} target="_blank" rel="noopener">@parthenonbarbearia</a>
            </div>
          </div>
          <div class="map">
            <iframe
              src="https://maps.google.com/maps?q=Rua+da+Fartura,+1767,+Uberlândia,+MG,+Brasil&output=embed&hl=pt-BR"
              title="Localização da Parthenon Barbearia"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </div>
    </section>

    <footer class="footer">
      <img src="/logo.png" alt="Parthenon Barbearia" />
      <strong>Parthenon Barbearia</strong>
      <p>&copy; 2025 Barbearia Parthenon — Uberlândia, MG</p>
    </footer>
  </div>
</body>
</html>
